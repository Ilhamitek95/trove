# ---- Server ----
PORT=4242

# This site's own public URL — used for Stripe Connect return links.
# Single-origin (recommended): the backend also serves the storefront, so this is
# just the site address. Local dev → http://localhost:4242. In production →
# your real URL, e.g. https://trove.onrender.com (no trailing slash).
CLIENT_URL=http://localhost:4242

# Set to "production" on your host so cookies are sent over HTTPS only.
NODE_ENV=development

# Only set CROSS_SITE=1 if you host the storefront on a DIFFERENT domain than
# this API (split hosting). Then CLIENT_URL may be a comma-separated allow-list.
# CROSS_SITE=1

SESSION_SECRET=replace-with-a-long-random-string

# ---- Stripe ----
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen --forward-to localhost:4242/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Marketplace ----
# Trove's cut of each shop's sales (applies to BOTH payout types).
PLATFORM_FEE_PERCENT=10
# Buyer fees, in fils (1 AED = 100). Service fee is flat; delivery is charged per
# order but waived once the cart subtotal reaches the free-delivery threshold.
SERVICE_FEE_CENTS=900
DELIVERY_FEE_CENTS=2500
FREE_DELIVERY_THRESHOLD_CENTS=50000
CURRENCY=aed

# ---- Database ----
# Where the SQLite file lives. In production point this at a persistent disk so
# data survives redeploys, e.g. DB_PATH=/var/data/trove.db
# DB_PATH=
