# ---- Server ----
PORT=4242
# Where your storefront is served from (for CORS + Stripe redirect URLs).
# If you open the HTML files directly they run on file:// — serve them instead, e.g. `npx serve` on 3000.
CLIENT_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-string

# ---- Stripe ----
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen --forward-to localhost:4242/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Marketplace ----
PLATFORM_FEE_PERCENT=8
CURRENCY=aed
